# Environment Configuration for Incauca Labs
# Copy this file to .env and use with:
# flutter run --dart-define-from-file=.env
# or
# flutter build <platform> --dart-define-from-file=.env

# Environment Selection: local | cloud
ENVIRONMENT=local

# --- LOCAL CONFIGURATION ---
LOCAL_BASE_URL=10.147.17.100:8000
LOCAL_UPLOAD_ENDPOINT=/analysis/upload

# --- CLOUD (AZURE) CONFIGURATION ---
AZURE_API_BASE_URL=https://incauca-linux-function-app.azurewebsites.net/api
AZURE_NEGOTIATE_ENDPOINT=/negotiate
AZURE_GENERATE_UPLOAD_URL_ENDPOINT=/generate_upload_urls

# Cosmos DB
COSMOS_DB_ENDPOINT=https://your-cosmos-db.documents.azure.com:443/
COSMOS_DB_KEY=your_cosmos_db_key
COSMOS_DB_DATABASE=incauca-cosmosdb-database
COSMOS_DB_CONTAINER=incauca-cosmosdb-container

# Storage
STORAGE_ACCOUNT_URL=https://your-storage-account.blob.core.windows.net
STORAGE_CONTAINER_NAME=images
