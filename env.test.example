# Test Environment Configuration Example
# Copy this file to .env.test for local E2E testing
ENVIRONMENT=local

# Use 10.0.2.2 for Android Emulator to point to localhost
LOCAL_BASE_URL=http://10.0.2.2:8001/api
LOCAL_UPLOAD_ENDPOINT=/analysis/upload

# Credentials for E2E Tests (must match seeded data in backend)
E2E_TEST_EMAIL=admin@incauca.com
E2E_TEST_PASSWORD=admin123
